{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@/*": ["./src/*"],
      "@spartan-ng/helm/sidebar": ["./libs/ui/sidebar/src/index.ts"],
      "@spartan-ng/helm/utils": ["./libs/ui/utils/src/index.ts"],
      "@spartan-ng/helm/button": ["./libs/ui/button/src/index.ts"],
      "@spartan-ng/helm/icon": ["./libs/ui/icon/src/index.ts"],
      "@spartan-ng/helm/input": ["./libs/ui/input/src/index.ts"],
      "@spartan-ng/helm/separator": ["./libs/ui/separator/src/index.ts"],
      "@spartan-ng/helm/sheet": ["./libs/ui/sheet/src/index.ts"],
      "@spartan-ng/helm/skeleton": ["./libs/ui/skeleton/src/index.ts"],
      "@spartan-ng/helm/tooltip": ["./libs/ui/tooltip/src/index.ts"],
      "@spartan-ng/helm/breadcrumb": ["./libs/ui/breadcrumb/src/index.ts"],
      "@spartan-ng/helm/dropdown-menu": ["./libs/ui/dropdown-menu/src/index.ts"],
      "@spartan-ng/helm/collapsible": ["./libs/ui/collapsible/src/index.ts"],
      "@spartan-ng/helm/avatar": ["./libs/ui/avatar/src/index.ts"],
      "@spartan-ng/helm/input-group": ["./libs/ui/input-group/src/index.ts"],
      "@spartan-ng/helm/textarea": ["./libs/ui/textarea/src/index.ts"],
      "@spartan-ng/helm/sonner": ["./libs/ui/sonner/src/index.ts"],
      "@spartan-ng/helm/label": ["./libs/ui/label/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
